{
  "name": "dbsc-toolkit",
  "version": "2.9.12",
  "description": "Server-side Device Bound Session Credentials (DBSC) for Node.js plus a Web Crypto polyfill for Firefox, Safari, and older Chromium. Cookie-theft protection on every modern browser.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/express/index.js",
      "types": "./dist/express/index.d.ts"
    },
    "./fastify": {
      "import": "./dist/fastify/index.js",
      "types": "./dist/fastify/index.d.ts"
    },
    "./hono": {
      "import": "./dist/hono/index.js",
      "types": "./dist/hono/index.d.ts"
    },
    "./nextjs": {
      "import": "./dist/nextjs/index.js",
      "types": "./dist/nextjs/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./storage/memory": {
      "import": "./dist/storage/memory/index.js",
      "types": "./dist/storage/memory/index.d.ts"
    },
    "./storage/redis": {
      "import": "./dist/storage/redis/index.js",
      "types": "./dist/storage/redis/index.d.ts"
    },
    "./storage/postgres": {
      "import": "./dist/storage/postgres/index.js",
      "types": "./dist/storage/postgres/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "peerDependencies": {
    "@fastify/cookie": ">=11.0.0",
    "express": ">=5.0.0",
    "fastify": ">=5.0.0",
    "hono": ">=4.0.0",
    "ioredis": ">=5.0.0",
    "next": ">=15.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "@fastify/cookie": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@fastify/cookie": "^11.0.2",
    "fastify-plugin": "^5.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "fake-indexeddb": "^6.2.5",
    "fastify": "^5.8.5",
    "hono": "^4.0.0",
    "ioredis": "^5.3.0",
    "jsdom": "^29.1.1",
    "next": "^16.2.6",
    "pg": "^8.11.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "dbsc",
    "device-bound-session-credentials",
    "session",
    "security",
    "tpm",
    "auth",
    "cookies",
    "webauthn",
    "express",
    "fastify",
    "hono",
    "nextjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SulimanAbdulrazzaq/dbsc-toolkit.git"
  },
  "homepage": "https://github.com/SulimanAbdulrazzaq/dbsc-toolkit#readme",
  "bugs": {
    "url": "https://github.com/SulimanAbdulrazzaq/dbsc-toolkit/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
